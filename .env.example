# Anti-abuse: salt for sha256-hashing IPs and user-agents in v2_abuse_events.
# Rotate annually. If unset, abuse events are still logged but ip_hash/ua_hash
# will be null (no raw PII is ever stored).
ABUSE_HASH_SALT=

# Admin command center (single-operator stopgap until Phase D Clerk rollout).
# Required for /admin and /admin/login to function.
#   ADMIN_PASSWORD: operator-chosen password. Plaintext in env; hashed in cookies.
#   ADMIN_SESSION_SECRET: ≥32-char random hex. Generate with: openssl rand -hex 32
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
