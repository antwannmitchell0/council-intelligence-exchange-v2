NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
INGEST_WEBHOOK_SECRET=
CRON_SECRET=
FRED_API_KEY=
BLS_API_KEY=
OPENFIGI_API_KEY=
SEC_USER_AGENT=
ETHERSCAN_API_KEY=
ALPACA_API_KEY_ID=
ALPACA_API_SECRET=
ALPACA_WEBHOOK_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anti-abuse: salt for sha256-hashing IPs and user-agents in v2_abuse_events.
# Rotate annually. If unset, abuse events are still logged but ip_hash/ua_hash
# will be null (no raw PII is ever stored).
ABUSE_HASH_SALT=

# Admin command center (single-operator stopgap until Phase D Clerk rollout).
# Required for /admin and /admin/login to function.
#   ADMIN_PASSWORD: operator-chosen password. Plaintext in env; hashed in cookies.
#   ADMIN_SESSION_SECRET: ≥32-char random hex. Generate with: openssl rand -hex 32
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Operational alerts (cron failures, etc.) — supports Slack OR Discord.
# Auto-detects platform from URL host:
#   Slack:   https://hooks.slack.com/services/...
#   Discord: https://discord.com/api/webhooks/...
# If unset, alerts are silent no-ops (local dev / preview deploys keep working).
ALERT_WEBHOOK_URL=

# Sentry error tracking — Next.js SDK v10+.
# DSN is NOT a secret (it's designed to be embedded in browser code);
# restricting who can submit events happens on Sentry's side via project-
# level allowed-domains. NEXT_PUBLIC_ prefix is required for client
# access; server-side can use either prefix.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Stripe — Early Access subscription billing (pre-Phase-D MVP).
# Payment Link URL is public — anyone can have it; it just opens Stripe's
# hosted checkout. Webhook secret IS a real secret used to verify
# inbound webhook authenticity.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — transactional email + daily digest.
# RESEND_API_KEY: starts with `re_...`
# RESEND_OPERATIONAL_SENDER: e.g. "Council Intelligence <info@demmmarketing.com>"
#   Falls back to onboarding@resend.dev until your domain is verified.
# RESEND_REPLY_TO: where customer replies land (operator inbox).
RESEND_API_KEY=
RESEND_OPERATIONAL_SENDER=
RESEND_REPLY_TO=

# Discord subscriber invite — link given to new subscribers in the
# welcome email. Generate via Discord channel settings → Invites → "Edit
# invite" → set to never expire. Distinct from the operator alerts
# channel (those alerts go to the existing ALERT_WEBHOOK_URL).
DISCORD_SUBSCRIBER_INVITE_URL=
